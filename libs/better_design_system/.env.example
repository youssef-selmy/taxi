# BetterUI - Docker Publishing Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# GitHub Personal Access Token
# Required for:
#   - Authenticating with GitHub Container Registry (GHCR)
#   - Cloning private flutter_localizations repository
#
# To create a token:
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Select scopes:
#      - repo (Full control of private repositories)
#      - write:packages (Upload packages to GitHub Package Registry)
#      - read:packages (Download packages from GitHub Package Registry)
#   4. Generate token and copy it here
GITHUB_TOKEN=your_github_personal_access_token_here

# GitHub Container Registry Username
# This is typically your GitHub username or organization name
# Default: LumeAgency (will be used if not set)
GHCR_USERNAME=LumeAgency

# Usage:
# ------
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env and add your GITHUB_TOKEN
#
# 3. Source the environment file before running the script:
#    source .env
#    ./tools/docker-publish.sh
#
# Or export variables manually:
#    export GITHUB_TOKEN=your_token_here
#    export GHCR_USERNAME=LumeAgency
#    ./tools/docker-publish.sh
