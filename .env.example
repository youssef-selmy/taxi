NODE_ENV=prod # dev, staging or prod
FORCE_SYNC_DB=false # Set to true to force sync the database schema on startup. Use with caution in production.
REQUEST_EXPIRATION=10 # in minutes
GATEWAY_SERVER_URL=http://127.0.0.1:3333
RIDER_SERVER_URL=http://127.0.0.1:3001
DRIVER_SERVER_URL=http://127.0.0.1:3002
MYSQL_HOST=127.0.0.1
MYSQL_DB=bettersuite
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=defaultpassword
MYSQL_ROOT_PASSWORD=defaultpassword # Duplicate for mysql container use
# Redis Configuration
# Option 1: Connection URL (recommended for production/AWS Secrets Manager)
REDIS_URL=redis://127.0.0.1:6379
# Option 2: Individual variables (legacy, used as fallback if REDIS_URL not set)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASS=
DEMO_MODE=false
PASSWORD_REQUIRED=true # Set to false to disable password authentication (all users use OTP, skip password setup)
DRIVER_MINIMUM_ALLOWED_BALANCE=0 # Minimum wallet balance required for driver to stay online. Driver will be taken offline if balance falls below this value after a trip (e.g., after cash payment commission deduction). Set to 0 to disable.
ENCRYPTION_KEY=lPw3ethAy4WqnWa3b484bCdXUQCRifEH # Replace with your own secure key, Used to communicate encrypted sensitive data between APIs
RIDER_API_PORT=3001
DRIVER_API_PORT=3002
FLEET_API_PORT=3003
ADMIN_API_PORT=3004
RIDER_APPLICATION_ID=com.bettersuite.taxi.rider # Used to redirect back into the app after browser payment
DRIVER_APPLICATION_ID=com.bettersuite.taxi.driver # Used to redirect back into the app after browser payment
SENTRY_AUTH_TOKEN=
SENTRY_DSN_RIDER_API=
SENTRY_DSN_DRIVER_API=
SENTRY_DSN_PAYMENT_API=
SENTRY_DSN_ADMIN_API=
SENTRY_FLEET_API=
STORAGE_DRIVER=local # Options are: local, s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_BASE_URL=
# AWS Secrets Manager (optional - load sensitive variables from AWS)
USE_AWS_SECRETS_MANAGER=false # Set to true to load secrets from AWS Secrets Manager
AWS_SECRET_NAME= # Name of the secret in AWS (e.g., bettersuite/prod)
# When enabled, the following variables can be loaded from the secret:
# MYSQL_HOST, MYSQL_PORT, MYSQL_USER, MYSQL_PASS, MYSQL_DB
# REDIS_HOST, REDIS_PORT, REDIS_PASS
# Any other sensitive variables stored in your AWS secret
CHATWOOT_HMAC_TOKEN= # HMAC token for secure Chatwoot integration
# Apple App Site Association (for passkey and universal links)
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID # Find this in Apple Developer Portal under Membership Details
RIDER_BUNDLE_ID=com.bettersuite.bettertaxi.rider
DRIVER_BUNDLE_ID=com.bettersuite.bettertaxi.driver
# Android Digital Asset Links (for passkey and app links)
RIDER_ANDROID_SHA256_FINGERPRINT= # SHA256 fingerprint from your Android signing key
DRIVER_ANDROID_SHA256_FINGERPRINT= # SHA256 fingerprint from your Android signing key
# Passkey / WebAuthn Configuration
PASSKEY_RP_ID=yourdomain.com
PASSKEY_RP_NAME=BetterTaxi
PASSKEY_ORIGIN=https://yourdomain.com
PASSWORD_REQUIRED=false